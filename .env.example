# MySQL 运维平台 - 4 个必填 env
# 复制到 .env 并填值. start.ps1 自动加载 .env

# 平台后端 DSN (MySQL 或 SQLite). 含 @ 等特殊字符请用 go 风格转义.
DBOPS_DB_URL=root:password@tcp(10.1.81.41:3306)/dbops_platform?charset=utf8mb4&parseTime=true&loc=Local

# JWT 签名密钥 (>= 32 字符)
DBOPS_JWT_SECRET=dev-jwt-secret-CHANGE-ME-at-least-32-chars-please

# AES-GCM 加密密钥 (>= 32 字符)
DBOPS_ENCRYPTION_KEY=dev-aes-key-CHANGE-ME-at-least-32-chars-please

# Agent 鉴权 token (>= 16 字符, 与 agent/config.yaml 的 agent_token 一致)
DBOPS_AGENT_TOKEN=dev-agent-token-CHANGE-ME-at-least-16

# 可选: storage_mode (auto | mysql | sqlite), 默认 auto
# DBOPS_STORAGE_MODE=mysql

# 可选: CORS 白名单 (逗号分隔)
# DBOPS_ALLOWED_ORIGINS=http://localhost:3000,http://10.1.81.41:3000
