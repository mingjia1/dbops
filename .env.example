# Copy this file to .env for local development only.
# Do not commit real credentials or environment-specific endpoints.

DBOPS_SERVER_PORT=8080
DBOPS_TLS_CERT_PATH=
DBOPS_TLS_KEY_PATH=
DBOPS_LOG_LEVEL=info
DBOPS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
DBOPS_SERVER_READ_TIMEOUT_SEC=15
DBOPS_SERVER_WRITE_TIMEOUT_SEC=60
DBOPS_SERVER_IDLE_TIMEOUT_SEC=120
DBOPS_MAX_MULTIPART_MEMORY=10485760
DBOPS_HEALTH_CHECK_TIMEOUT=2s

DBOPS_STORAGE_MODE=mysql
DBOPS_DB_URL=dbops_user:replace-with-strong-password@tcp(127.0.0.1:3306)/dbops_platform?parseTime=true&loc=Local
DBOPS_SQLITE_PATH=./data/dbops.db
DBOPS_DATA_DIR=./data
DBOPS_REDIS_URL=127.0.0.1:6379
DBOPS_REDIS_PASSWORD=
DBOPS_REDIS_DB=0
DBOPS_CLICKHOUSE_URL=

DBOPS_JWT_SECRET=replace-with-strong-random-jwt-secret-at-least-32-chars
DBOPS_JWT_EXPIRY=24h
DBOPS_ENCRYPTION_KEY=replace-with-32-byte-random-encryption-key
DBOPS_AGENT_TOKEN=replace-with-strong-random-agent-token
DBOPS_ALLOW_INSECURE_DEV_SECRETS=0

DBOPS_REPLICATION_USER=repl
DBOPS_REPLICATION_PASS=replace-with-replication-password
DBOPS_SST_USER=sst
DBOPS_SST_PASS=replace-with-sst-password
DBOPS_SSH_USER=root

DBOPS_AI_BASE_URL=
DBOPS_AI_API_KEY=
DBOPS_AI_MODEL=
DBOPS_AI_MAX_TOKENS=4096
DBOPS_AI_TEMPERATURE=0.2

DBOPS_BACKUP_DIR=./data/backups
DBOPS_REPLICATION_LAG_THRESHOLD=300
DBOPS_LOGIN_RATELIMIT_DISABLE=false
DBOPS_SKIP_AGENT_BINARY_BUILD=false
