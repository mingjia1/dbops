e-width, initial-scale=1.0"}],"\n    ",["TITLE",{},"MySQL 运维平台"],"\n  ",["STYLE",{},".login-page {\r\n  display: flex;\r\n  min-height: 100vh;\r\n  background: var(--apple-bg);\r\n  font-family: var(--apple-font);\r\n}\r\n\r\n/* Brand panel — light, airy, soft gradient orbs */\r\n.login-brand {\r\n  flex: 1;\r\n  position: relative;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  background: linear-gradient(180deg, #F5F5F7 0%, #ECECEF 100%);\r\n  overflow: hidden;\r\n  padding: 40px;\r\n}\r\n\r\n.brand-orb {\r\n  position: absolute;\r\n  border-radius: 50%;\r\n  filter: blur(80px);\r\n  opacity: 0.5;\r\n  pointer-events: none;\r\n}\r\n.brand-orb-1 { width: 480px; height: 480px; background: #0071E3; top: -120px; left: -120px; opacity: 0.18; }\r\n.brand-orb-2 { width: 420px; height: 420px; background: #AF52DE; bottom: -100px; right: -80px; opacity: 0.15; }\r\n.brand-orb-3 { width: 320px; height: 320px; background: #5AC8FA; top: 40%; left: 55%; opacity: 0.18; }\r\n\r\n.brand-content {\r\n  position: relative;\r\n  z-index: 1;\r\n  text-align: center;\r\n  max-width: 520px;\r\n}\r\n\r\n.brand-title {\r\n  font-size: 40px;\r\n  font-weight: 700;\r\n  color: #1D1D1F;\r\n  margin: 0 0 8px;\r\n  letter-spacing: -0.03em;\r\n}\r\n.brand-desc {\r\n  font-size: 17px;\r\n  color: #6E6E73;\r\n  margin: 0 0 36px;\r\n  font-weight: 400;\r\n}\r\n\r\n.brand-feature-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(2, 1fr);\r\n  gap: 14px;\r\n  margin: 0 auto;\r\n  max-width: 460px;\r\n}\r\n.brand-feature {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  padding: 14px;\r\n  background: rgba(255, 255, 255, 0.6);\r\n  backdrop-filter: blur(20px);\r\n  -webkit-backdrop-filter: blur(20px);\r\n  border-radius: 14px;\r\n  border: 0.5px solid rgba(60, 60, 67, 0.08);\r\n  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.03);\r\n  text-align: left;\r\n  transition: all 280ms cubic-bezier(0.32, 0.72, 0, 1);\r\n}\r\n.brand-feature:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08); }\r\n.brand-feature-icon {\r\n  width: 38px; height: 38px; border-radius: 10px;\r\n  display: flex; align-items: center; justify-content: center;\r\n  font-size: 18px; color: #fff; flex-shrink: 0;\r\n}\r\n.brand-feature-title { font-size: 14px; font-weight: 600; color: #1D1D1F; line-height: 1.2; }\r\n.brand-feature-desc { font-size: 12px; color: #6E6E73; margin-top: 2px; }\r\n\r\n.brand-footer {\r\n  margin-top: 40px;\r\n  color: #AEAEB2;\r\n  font-size: 12px;\r\n  letter-spacing: 0.02em;\r\n}\r\n\r\n/* Form panel */\r\n.login-form-wrap {\r\n  width: 480px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  padding: 40px;\r\n}\r\n\r\n.login-card {\r\n  width: 100%;\r\n  background: #FFFFFF;\r\n  border-radius: 20px;\r\n  padding: 36px 36px 28px;\r\n  box-shadow:\r\n    0 1px 2px rgba(0, 0, 0, 0.04),\r\n    0 20px 50px rgba(0, 0, 0, 0.08),\r\n    0 0 0 0.5px rgba(0, 0, 0, 0.04);\r\n}\r\n\r\n.login-card-header { text-align: center; margin-bottom: 24px; }\r\n.login-card-title { font-size: 24px; font-weight: 700; color: #1D1D1F; letter-spacing: -0.025em; }\r\n.login-card-sub { font-size: 14px; color: #6E6E73; margin-top: 4px; }\r\n\r\n.login-card .ant-tabs .ant-tabs-tab { font-size: 15px; padding: 10px 0; }\r\n.login-card .ant-tabs .ant-tabs-tab-active { font-weight: 600; }\r\n.login-card .ant-tabs-top > .ant-tabs-nav { margin-bottom: 24px; }\r\n.login-card .ant-tabs-ink-bar { background: #0071E3; height: 2.5px; border-radius: 2px; }\r\n\r\n.login-card .ant-form-item { margin-bottom: 18px; }\r\n.login-card .ant-input,\r\n.login-card .ant-input-affix-wrapper { border-radius: 10px !important; padding: 8px 12px; }\r\n.login-card .ant-input-affix-wrapper { padding-left: 12px; }\r\n.login-card .ant-input-affix-wrapper .anticon { color: rgba(60, 60, 67, 0.4); }\r\n\r\n.login-card-foot {\r\n  margin-top: 18px;\r\n  padding-top: 16px;\r\n  border-top: 0.5px solid var(--apple-separator);\r\n  text-align: center;\r\n  color: #AEAEB2;\r\n  font-size: 12px;\r\n}\r\n\r\n.login-btn {\r\n  height: 44px;\r\n  font-size: 15px;\r\n  font-weight: 600;\r\n  border-radius: 12px;\r\n  background: linear-gradient(135deg, #0071E3 0%, #0077ED 100%);\r\n  border: none;\r\n  letter-spacing: 0.02em;\r\n  box-shadow: 0 4px 12px rgba(0, 113, 227, 0.25);\r\n  transition: all 220ms cubic-bezier(0.32, 0.72, 0, 1);\r\n}\r\n.login-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(0, 113, 227, 0.35); }\r\n.login-btn:active { transform: translateY(0); }\r\n\r\n/* Responsive */\r\n@media (max-width: 960px) {\r\n  .login-page { flex-direction: column; }\r\n  .login-brand { min-height: 280px; padding: 32px 20px; }\r\n  .login-form-wrap { width: 100%; padding: 24px 20px 40px; }\r\n  .brand-title { font-size: 30px; }\r\n  .brand-desc { font-size: 15px; margin-bottom: 24px; }\r\n  .brand-feature-grid { grid-template-columns: 1fr 1fr; gap: 10px; }\r\n}\r\n@media (max-width: 560px) {\r\n  .brand-feature-grid { grid-template-columns: 1fr; }\r\n  .login-card { padding: 28px 22px; }\r\n}\r\n"],["STYLE",{},"/* Apple-style dashboard shell: translucent header, glass sidebar, light bg */\r\n.dashboard-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  background: rgba(255, 255, 255, 0.72) !important;\r\n  backdrop-filter: saturate(180%) blur(20px);\r\n  -webkit-backdrop-filter: saturate(180%) blur(20px);\r\n  padding: 0 24px;\r\n  height: 52px;\r\n  line-height: 52px;\r\n  border-bottom: 0.5px solid var(--apple-separator);\r\n  position: sticky;\r\n  top: 0;\r\n  z-index: 100;\r\n}\r\n\r\n.header-left {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 10px;\r\n}\r\n\r\n.header-logo {\r\n  width: 30px;\r\n  height: 30px;\r\n  background: linear-gradient(135deg, #0071E3, #5AC8FA);\r\n  border-radius: 8px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 16px;\r\n  color: #fff;\r\n  box-shadow: 0 2px 6px rgba(0, 113, 227, 0.25);\r\n}\r\n\r\n.header-right {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 16px;\r\n}\r\n\r\n.dashboard-sider {\r\n  background: rgba(245, 245, 247, 0.85) !important;\r\n  backdrop-filter: saturate(180%) blur(20px);\r\n  -webkit-backdrop-filter: saturate(180%) blur(20px);\r\n  border-right: 0.5px solid var(--apple-separator) !important;\r\n}\r\n\r\n.dashboard-sider .ant-menu {\r\n  background: transparent;\r\n  border-inline-end: none !important;\r\n  padding: 12px 8px;\r\n}\r\n\r\n.dashboard-sider .ant-menu-item,\r\n.dashboard-sider .ant-menu-submenu-title {\r\n  margin: 2px 8px !important;\r\n  width: calc(100% - 16px) !important;\r\n  border-radius: 8px !important;\r\n  color: rgba(60, 60, 67, 0.78) !important;\r\n  font-weight: 500;\r\n  font-size: 13.5px;\r\n  height: 36px;\r\n  line-height: 36px;\r\n  transition: all 180ms cubic-bezier(0.32, 0.72, 0, 1);\r\n}\r\n\r\n.dashboard-sider .ant-menu-item:hover,\r\n.dashboard-sider .ant-menu-submenu-title:hover {\r\n  color: #1D1D1F !important;\r\n  background: rgba(0, 0, 0, 0.04) !important;\r\n}\r\n\r\n.dashboard-sider .ant-menu-item-selected {\r\n  color: #FFFFFF !important;\r\n  background: linear-gradient(135deg, #0071E3 0%, #0077ED 100%) !important;\r\n  font-weight: 600;\r\n  box-shadow: 0 4px 12px rgba(0, 113, 227, 0.30);\r\n}\r\n\r\n.dashboard-sider .ant-menu-item-selected::before,\r\n.dashboard-sider .ant-menu-submenu-selected > .ant-menu-submenu-title::before {\r\n  display: none;\r\n}\r\n\r\n.dashboard-sider .ant-menu-submenu-selected > .ant-menu-submenu-title {\r\n  color: #1D1D1F !important;\r\n  background: rgba(0, 0, 0, 0.04) !important;\r\n}\r\n\r\n.dashboard-sider .ant-menu-sub {\r\n  background: transparent !important;\r\n  border-radius: 8px;\r\n  margin: 0 8px !important;\r\n  padding: 2px 0 !important;\r\n}\r\n.dashboard-sider .ant-menu-sub .ant-menu-item {\r\n  margin: 1px 12px !important;\r\n  width: calc(100% - 24px) !important;\r\n  font-size: 13px;\r\n  color: rgba(60, 60, 67, 0.62) !important;\r\n  padding-left: 36px !important;\r\n}\r\n.dashboard-sider .ant-menu-sub .ant-menu-item-selected {\r\n  background: rgba(0, 113, 227, 0.10) !important;\r\n  color: #0071E3 !important;\r\n  font-weight: 600;\r\n  box-shadow: none;\r\n}\r\n\r\n.dashboard-sider .ant-menu-item .anticon,\r\n.dashboard-sider .ant-menu-submenu-title .anticon {\r\n  color: inherit !important;\r\n  font-size: 16px;\r\n}\r\n\r\n.dashboard-content {\r\n  padding: 0;\r\n  background: var(--apple-bg);\r\n  min-height: calc(100vh - 52px);\r\n  overflow-y: auto;\r\n}\r\n\r\n/* User pill in header */\r\n.user-pill {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  padding: 4px 10px 4px 4px;\r\n  border-radius: 980px;\r\n  background: rgba(120, 120, 128, 0.08);\r\n  color: #1D1D1F;\r\n  cursor: pointer;\r\n  transition: all 180ms cubic-bezier(0.32, 0.72, 0, 1);\r\n  line-height: 1.4;\r\n}\r\n.user-pill:hover { background: rgba(120, 120, 128, 0.16); }\r\n.user-pill .ant-avatar { background: linear-gradient(135deg, #0071E3, #5856D6) !important; }\r\n\r\n:root[data-theme=\"dark\"] .dashboard-header {\r\n  background: rgba(28, 28, 30, 0.86) !important;\r\n}\r\n\r\n:root[data-theme=\"dark\"] .dashboard-sider {\r\n  background: rgba(28, 28, 30, 0.92) !important;\r\n}\r\n\r\n:root[data-theme=\"dark\"] .dashboard-sider .ant-menu-item,\r\n:root[data-theme=\"dark\"] .dashboard-sider .ant-menu-submenu-title {\r\n  color: rgba(245, 245, 247, 0.76) !important;\r\n}\r\n\r\n:root[data-theme=\"dark\"] .dashboard-sider .ant-menu-item:hover,\r\n:root[data-theme=\"dark\"] .dashboard-sider .ant-menu-submenu-title:hover,\r\n:root[data-theme=\"dark\"] .dashboard-sider .ant-menu-submenu-selected > .ant-menu-submenu-title {\r\n  color: #F5F5F7 !important;\r\n  background: rgba(255, 255, 255, 0.08) !important;\r\n}\r\n\r\n:root[data-theme=\"dark\"] .dashboard-sider .ant-menu-sub .ant-menu-item {\r\n  color: rgba(245, 245, 247, 0.62) !important;\r\n}\r\n\r\n:root[data-theme=\"dark\"] .dashboard-sider .ant-menu-sub .ant-menu-item-selected {\r\n  background: rgba(10, 132, 255, 0.18) !important;\r\n  color: #64D2FF !important;\r\n}\r\n"],["STYLE",{},"body {\r\n  margin: 0;\r\n  padding: 0;\r\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen',\r\n    'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue',\r\n    sans-serif;\r\n  -webkit-font-smoothing: antialiased;\r\n  -moz-osx-font-smoothing: grayscale;\r\n}\r\n\r\n#root {\r\n  min-height: 100vh;\r\n}"],["STYLE",{},"/* Apple Design System — global tokens\r\n   Inspired by macOS Sonoma / iOS 17 / visionOS\r\n   Colors tuned to neutral pastel + SF system palette\r\n*/\r\n\r\n:root {\r\n  /* Surfaces */\r\n  --apple-bg: #F5F5F7;\r\n  --apple-bg-elevated: #FFFFFF;\r\n  --apple-bg-grouped: #FAFAFC;\r\n  --apple-bg-sidebar: rgba(245, 245, 247, 0.72);\r\n  --apple-bg-header: rgba(255, 255, 255, 0.72);\r\n  --apple-bg-tint: rgba(0, 113, 227, 0.04);\r\n\r\n  /* Strokes */\r\n  --apple-separator: rgba(60, 60, 67, 0.10);\r\n  --apple-separator-strong: rgba(60, 60, 67, 0.18);\r\n  --apple-border: rgba(60, 60, 67, 0.08);\r\n\r\n  /* Text */\r\n  --apple-text: #1D1D1F;\r\n  --apple-text-secondary: #6E6E73;\r\n  --apple-text-tertiary: #AEAEB2;\r\n\r\n  /* Accents */\r\n  --apple-blue: #0071E3;\r\n  --apple-blue-hover: #0077ED;\r\n  --apple-blue-tint: rgba(0, 113, 227, 0.10);\r\n  --apple-green: #34C759;\r\n  --apple-green-tint: rgba(52, 199, 89, 0.10);\r\n  --apple-orange: #FF9500;\r\n  --apple-orange-tint: rgba(255, 149, 0, 0.10);\r\n  --apple-red: #FF3B30;\r\n  --apple-red-tint: rgba(255, 59, 48, 0.10);\r\n  --apple-purple: #AF52DE;\r\n  --apple-pink: #FF2D55;\r\n  --apple-indigo: #5856D6;\r\n  --apple-teal: #5AC8FA;\r\n  --apple-yellow: #FFCC00;\r\n\r\n  /* Shadows — soft, layered */\r\n  --apple-shadow-1: 0 1px 2px rgba(0, 0, 0, 0.04), 0 0 0 0.5px rgba(0, 0, 0, 0.04);\r\n  --apple-shadow-2: 0 2px 8px rgba(0, 0, 0, 0.06), 0 0 0 0.5px rgba(0, 0, 0, 0.04);\r\n  --apple-shadow-3: 0 4px 16px rgba(0, 0, 0, 0.08), 0 0 0 0.5px rgba(0, 0, 0, 0.04);\r\n  --apple-shadow-4: 0 12px 40px rgba(0, 0, 0, 0.12), 0 0 0 0.5px rgba(0, 0, 0, 0.04);\r\n\r\n  /* Radii */\r\n  --apple-radius-sm: 6px;\r\n  --apple-radius: 10px;\r\n  --apple-radius-lg: 14px;\r\n  --apple-radius-xl: 20px;\r\n\r\n  /* Motion */\r\n  --apple-ease: cubic-bezier(0.32, 0.72, 0, 1);\r\n  --apple-ease-spring: cubic-bezier(0.5, 1.6, 0.4, 1);\r\n  --apple-fast: 180ms;\r\n  --apple-normal: 280ms;\r\n  --apple-slow: 480ms;\r\n\r\n  /* Typography */\r\n  --apple-font: -apple-system, BlinkMacSystemFont, \"SF Pro Text\", \"SF Pro Display\", \"PingFang SC\", \"Helvetica Neue\", Arial, \"Segoe UI\", sans-serif;\r\n}\r\n\r\n* {\r\n  -webkit-font-smoothing: antialiased;\r\n  -moz-osx-font-smoothing: grayscale;\r\n  text-rendering: optimizeLegibility;\r\n}\r\n\r\nbody {\r\n  font-family: var(--apple-font);\r\n  background: var(--apple-bg);\r\n  color: var(--apple-text);\r\n  letter-spacing: -0.011em;\r\n}\r\n\r\n/* Reusable glass card */\r\n.apple-card {\r\n  background: var(--apple-bg-elevated);\r\n  border-radius: var(--apple-radius-lg);\r\n  box-shadow: var(--apple-shadow-1);\r\n  border: 0.5px solid var(--apple-border);\r\n  padding: 20px;\r\n  transition: box-shadow var(--apple-normal) var(--apple-ease), transform var(--apple-normal) var(--apple-ease);\r\n}\r\n.apple-card:hover { box-shadow: var(--apple-shadow-2); }\r\n.apple-card.is-interactive:hover { transform: translateY(-2px); box-shadow: var(--apple-shadow-3); cursor: pointer; }\r\n\r\n/* Apple-style stat card */\r\n.apple-stat {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 14px;\r\n  padding: 18px 20px;\r\n  background: var(--apple-bg-elevated);\r\n  border-radius: var(--apple-radius-lg);\r\n  box-shadow: var(--apple-shadow-1);\r\n  border: 0.5px solid var(--apple-border);\r\n}\r\n.apple-stat-icon {\r\n  width: 44px;\r\n  height: 44px;\r\n  border-radius: 12px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 22px;\r\n  color: #fff;\r\n  flex-shrink: 0;\r\n}\r\n.apple-stat-body { flex: 1; min-width: 0; }\r\n.apple-stat-label { font-size: 12px; color: var(--apple-text-secondary); font-weight: 500; }\r\n.apple-stat-value { font-size: 26px; font-weight: 600; color: var(--apple-text); margin-top: 2px; line-height: 1.1; letter-spacing: -0.02em; }\r\n.apple-stat-trend { font-size: 11px; margin-top: 4px; }\r\n\r\n/* Section header */\r\n.apple-section {\r\n  margin-bottom: 24px;\r\n}\r\n.apple-section-header {\r\n  display: flex;\r\n  align-items: baseline;\r\n  justify-content: space-between;\r\n  margin-bottom: 14px;\r\n}\r\n.apple-section-title {\r\n  font-size: 22px;\r\n  font-weight: 700;\r\n  color: var(--apple-text);\r\n  letter-spacing: -0.02em;\r\n  margin: 0;\r\n}\r\n.apple-section-subtitle {\r\n  font-size: 13px;\r\n  color: var(--apple-text-secondary);\r\n  margin: 4px 0 0;\r\n}\r\n\r\n/* Apple-style button (override antd to align) */\r\n.apple-btn {\r\n  height: 36px;\r\n  padding: 0 18px;\r\n  border-radius: 980px; /* pill */\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n  background: var(--apple-blue);\r\n  color: #fff;\r\n  border: none;\r\n  cursor: pointer;\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 6px;\r\n  transition: all var(--apple-fast) var(--apple-ease);\r\n  box-shadow: 0 1px 2px rgba(0,0,0,0.05);\r\n}\r\n.apple-btn:hover { background: var(--apple-blue-hover); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0, 113, 227, 0.25); }\r\n.apple-btn:active { transform: translateY(0); }\r\n.apple-btn.is-ghost { background: transparent; color: var(--apple-blue); }\r\n.apple-btn.is-ghost:hover { background: var(--apple-blue-tint); }\r\n.apple-btn.is-secondary { background: rgba(120,120,128,0.12); color: var(--apple-text); }\r\n.apple-btn.is-secondary:hover { background: rgba(120,120,128,0.20); }\r\n\r\n/* Tag */\r\n.apple-tag {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  padding: 2px 10px;\r\n  font-size: 12px;\r\n  font-weight: 500;\r\n  border-radius: 980px;\r\n  background: var(--apple-blue-tint);\r\n  color: var(--apple-blue);\r\n}\r\n.apple-tag.is-green { background: var(--apple-green-tint); color: var(--apple-green); }\r\n.apple-tag.is-orange { background: var(--apple-orange-tint); color: var(--apple-orange); }\r\n.apple-tag.is-red { background: var(--apple-red-tint); color: var(--apple-red); }\r\n.apple-tag.is-gray { background: rgba(120,120,128,0.12); color: var(--apple-text-secondary); }\r\n\r\n/* Empty state */\r\n.apple-empty {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  padding: 60px 24px;\r\n  color: var(--apple-text-secondary);\r\n  text-align: center;\r\n}\r\n.apple-empty-icon {\r\n  width: 56px;\r\n  height: 56px;\r\n  border-radius: 16px;\r\n  background: var(--apple-bg-grouped);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 28px;\r\n  color: var(--apple-text-tertiary);\r\n  margin-bottom: 14px;\r\n}\r\n.apple-empty-title { font-size: 15px; font-weight: 600; color: var(--apple-text); margin-bottom: 4px; }\r\n.apple-empty-desc { font-size: 13px; color: var(--apple-text-secondary); margin-bottom: 16px; max-width: 320px; }\r\n\r\n/* Page container with title */\r\n.apple-page {\r\n  padding: 28px 32px 40px;\r\n  max-width: 1440px;\r\n  margin: 0 auto;\r\n}\r\n.apple-page-title {\r\n  font-size: 28px;\r\n  font-weight: 700;\r\n  color: var(--apple-text);\r\n  letter-spacing: -0.025em;\r\n  margin: 0 0 4px;\r\n}\r\n.apple-page-subtitle {\r\n  font-size: 14px;\r\n  color: var(--apple-text-secondary);\r\n  margin: 0 0 28px;\r\n}\r\n\r\n/* Fade-in keyframe for page transitions */\r\n@keyframes apple-fade-in {\r\n  from { opacity: 0; transform: translateY(6px); }\r\n  to   { opacity: 1; transform: translateY(0); }\r\n}\r\n.apple-fade-in { animation: apple-fade-in var(--apple-normal) var(--apple-ease) both; }\r\n\r\n/* Override antd defaults that fight Apple style */\r\n.ant-card { border-radius: var(--apple-radius-lg) !important; border: 0.5px solid var(--apple-border) !important; box-shadow: var(--apple-shadow-1) !important; }\r\n.ant-card-head { border-bottom: 0.5px solid var(--apple-separator) !important; }\r\n.ant-card-head-title { font-weight: 600 !important; font-size: 15px !important; }\r\n.ant-table { font-size: 13px; }\r\n.ant-table-thead > tr > th { background: var(--apple-bg-grouped) !important; font-weight: 600 !important; color: var(--apple-text-secondary) !important; }\r\n.ant-table-tbody > tr { transition: background var(--apple-fast) var(--apple-ease); }\r\n.ant-table-tbody > tr:hover { background: var(--apple-bg-tint) !important; }\r\n.ant-btn { border-radius: 8px !important; transition: all var(--apple-fast) var(--apple-ease); }\r\n.ant-btn-primary { box-shadow: 0 1px 2px rgba(0, 113, 227, 0.15) !important; }\r\n.ant-tag { border-radius: 6px !important; padding: 1px 8px !important; font-size: 12px !important; }\r\n.ant-input, .ant-select-selector, .ant-picker { border-radius: 8px !important; }\r\n.ant-modal-content { border-radius: var(--apple-radius-lg) !important; }\r\n.ant-message-notice-content { border-radius: 10px !important; box-shadow: var(--apple-shadow-3) !important; }\r\n\r\n/* Scrollbar */\r\n::-webkit-scrollbar { width: 8px; height: 8px; }\r\n::-webkit-scrollbar-track { background: transparent; }\r\n::-webkit-scrollbar-thumb { background: rgba(60, 60, 67, 0.18); border-radius: 4px; }\r\n::-webkit-scrollbar-thumb:hover { background: rgba(60, 60, 67, 0.32); }\r\n\r\n/* Dark theme: html data-theme=\"dark\" 触发. main.tsx 启动时按 localStorage 设置.\r\n   仅覆写 token, antd darkAlgorithm 处理组件内色, CSS 这一层处理品牌背景/文字. */\r\n:root[data-theme=\"dark\"] {\r\n  --apple-bg: #000000;\r\n  --apple-bg-elevated: #1C1C1E;\r\n  --apple-bg-grouped: #2C2C2E;\r\n  --apple-bg-sidebar: rgba(28, 28, 30, 0.72);\r\n  --apple-bg-header: rgba(28, 28, 30, 0.72);\r\n  --apple-bg-tint: rgba(10, 132, 255, 0.10);\r\n  --apple-separator: rgba(255, 255, 255, 0.10);\r\n  --apple-separator-strong: rgba(255, 255, 255, 0.20);\r\n  --apple-border: rgba(255, 255, 255, 0.10);\r\n  --apple-text: #F5F5F7;\r\n  --apple-text-secondary: #A1A1A6;\r\n  --apple-text-tertiary: #6E6E73;\r\n  --apple-blue: #0A84FF;\r\n  --apple-blue-hover: #409CFF;\r\n  --apple-blue-tint: rgba(10, 132, 255, 0.15);\r\n  --apple-green: #30D158;\r\n  --apple-green-tint: rgba(48, 209, 88, 0.15);\r\n  --apple-orange: #FF9F0A;\r\n  --apple-orange-tint: rgba(255, 159, 10, 0.15);\r\n  --apple-red: #FF453A;\r\n  --apple-red-tint: rgba(255, 69, 58, 0.15);\r\n  --apple-purple: #BF5AF2;\r\n  --apple-pink: #FF375F;\r\n  --apple-indigo: #5E5CE6;\r\n  --apple-teal: #64D2FF;\r\n}\r\n\r\n:root[data-theme=\"dark\"] ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.20); }\r\n:root[data-theme=\"dark\"] ::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.32); }\r\n"]],"\n  ",["BODY",{},"\n    ",["DIV",{"id":"root"},["DIV",{"class":"css-dev-only-do-not-override-gz7h5j ant-app"},["DIV",{"class":"login-page"},["DIV",{"class":"login-brand"},["DIV",{"class":"brand-orb brand-orb-1"}],["DIV",{"class":"brand-orb brand-orb-2"}],["DIV",{"class":"brand-orb brand-orb-3"}],["DIV",{"class":"brand-content apple-fade-in"},["H1",{"class":"brand-title"},"MySQL 运维平台"],["P",{"class":"brand-desc"},"企业级数据库全生命周期管理"],["DIV",{"class":"brand-feature-grid"},["DIV",{"class":"brand-feature"},["DIV",{"class":"brand-feature-icon","style":"background: linear-gradient(135deg, rgb(0, 113, 227), rgb(90, 200, 250));"},["SPAN",{"role":"img","aria-label":"cloud","class":"anticon anticon-cloud"},["svg",{"viewBox":"64 64 896 896","focusable":"false","data-icon":"cloud","width":"1em","height":"1em","fill":"currentColor","aria-hidden":"true"},["path",{"d":"M811.4 418.7C765.6 297.9 648.9 212 512.2 212S258.8 297.8 213 418.6C127.3 441.1 64 519.1 64 612c0 110.5 89.5 200 199.9 200h496